@model List<PowerTrack.Models.EnergyConsumption>
@{
  ViewData["Title"] = "My Energy Records";
}

<h2>My Energy Records</h2>

<a class="btn btn-success mb-3" asp-controller="EnergyCreate" asp-action="Create">Add New Energy Record</a>

<table class="table table-bordered table-striped">
  <thead>
    <tr>
      <th>Year</th>
      <th>Month</th>
      <th>Consumption (kWh)</th>
      <th>Price per kWh</th>
      <th>Total Cost</th>
    </tr>
  </thead>
  <tbody>
    @foreach (var item in Model)
    {
      <tr>
        <td>@item.Year</td>
        <td>@item.Month</td>
        <td>@item.ConsumptionKWh</td>
        <td>@item.PricePerKWh</td>
        <td>@item.TotalCost</td>
      </tr>
    }
  </tbody>
</table>
