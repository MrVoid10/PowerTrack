@model PowerTrack.Models.User

<h2>Sign Up</h2>

<form asp-action="Signup" method="post">
  <div>
    <label>Name</label>
    <input asp-for="Name" />
  </div>
  <div>
    <label>Email</label>
    <input asp-for="Email" />
  </div>
  <div>
    <label>Password</label>
    <input asp-for="PasswordHash" type="password" />
  </div>
  <button type="submit">Sign Up</button>
</form>
