@{
  ViewData["Title"] = "Import Export Data";
  bool isAdmin = ViewBag.IsAdmin ?? false;
}

<h2>Import / Export Energy Data</h2>

<div class="mb-4">

  <!-- CSV EXPORT -->
  <div class="mb-3">
    <h5>Export</h5>

    @if (isAdmin)
    {
      <div class="form-check mb-2">
        <input class="form-check-input"
               type="checkbox"
               id="csvAllUsers" />
        <label class="form-check-label">
          Export for All Users
        </label>
      </div>
    }

    <button class="btn btn-success"
            onclick="exportCsv()">
      Export CSV
    </button>

    <button class="btn btn-info"
            onclick="exportJson()">
      Export JSON
    </button>
  </div>

</div>

<hr />

<h4>Import CSV</h4>

<form asp-controller="Export"
      asp-action="ImportCsv"
      method="post"
      enctype="multipart/form-data">

  <input type="file"
         name="file"
         class="form-control mb-2" />

  @if (isAdmin)
  {
    <div class="form-check mb-2">
      <input class="form-check-input"
             type="checkbox"
             name="allUsers"
             value="true" />
      <label class="form-check-label">
        Import for All Users
      </label>
    </div>
  }

  <button class="btn btn-primary">
    Import CSV
  </button>

</form>

<script>

  function exportCsv() {

      let allUsers =
          document.getElementById("csvAllUsers")?.checked ?? false;

      window.open(
          `/Export/ExportCsv?allUsers=${allUsers}`,
          "_blank"
      );
  }

  function exportJson() {

      let allUsers =
          document.getElementById("csvAllUsers")?.checked ?? false;

      window.open(
          `/Export/ExportJson?allUsers=${allUsers}`,
          "_blank"
      );
  }

</script>

