@model List<PowerTrack.Models.AuditLog>

<h2>Audit Logs</h2>

<form method="get" class="mb-4">

  <div class="row g-2">

    <!-- Search -->
    <div class="col-md-3">
      <input name="search"
             value="@ViewBag.Search"
             class="form-control"
             placeholder="Search..." />
    </div>

    <!-- Log Type -->
    <div class="col-md-2">
      <select name="logType" class="form-control">
        <option value="">All Types</option>
        <option value="INFO" selected="@(ViewBag.LogType == "INFO")">INFO</option>
        <option value="WARNING" selected="@(ViewBag.LogType == "WARNING")">WARNING</option>
        <option value="ERROR" selected="@(ViewBag.LogType == "ERROR")">ERROR</option>
      </select>
    </div>

    <!-- Action Filter -->
    <div class="col-md-2">
      <input name="actionFilter"
             value="@ViewBag.ActionFilter"
             class="form-control"
             placeholder="Action" />
    </div>

    <!-- User -->
    <div class="col-md-2">
      <input name="userId"
             value="@ViewBag.UserId"
             class="form-control"
             placeholder="User ID"
             type="number" />
    </div>

    <!-- Time Range -->
    <div class="col-md-3">
      <select id="timeRangeSelect" name="timeRange" class="form-control">
        <option value="all" selected="@(ViewBag.TimeRange == "all")">All Time</option>
        <option value="month" selected="@(ViewBag.TimeRange == "month")">Last Month</option>
        <option value="year" selected="@(ViewBag.TimeRange == "year")">Last Year</option>
        <option value="custom" selected="@(ViewBag.TimeRange == "custom")">Custom</option>
      </select>
    </div>

    <!-- Custom Date Range -->
    <div id="customDates" class="row g-2 @(ViewBag.TimeRange == "custom" ? "" : "d-none")">
      <div class="col-md-2">
        <input type="date"
               name="fromDate"
               value="@ViewBag.FromDate?.ToString("yyyy-MM-dd")"
               class="form-control" />
      </div>

      <div class="col-md-2">
        <input type="date"
               name="toDate"
               value="@ViewBag.ToDate?.ToString("yyyy-MM-dd")"
               class="form-control" />
      </div>
    </div>

    <div class="col-md-2">
      <button type="submit" class="btn btn-primary w-100">
        Filter
      </button>
    </div>

  </div>
</form>

<!-- Table -->
<table class="table table-bordered table-striped">
  <thead>
    <tr>
      <th>Time</th>
      <th>User</th>
      <th>Action</th>
      <th>Type</th>
      <th>Status</th>
      <th>Details</th>
    </tr>
  </thead>
  <tbody>
    @foreach (var log in Model)
    {
      <tr>
        <td>@log.Timestamp</td>
        <td>@log.UserId</td>
        <td>@log.Action</td>

        <td>
          <span class="badge bg-@(log.LogType == "ERROR" ? "danger" :
                                                log.LogType == "WARNING" ? "warning" :
                                                "success")">
            @log.LogType
          </span>
        </td>

        <td>@log.Status</td>
        <td>@log.Details</td>
      </tr>
    }
  </tbody>
</table>

<!-- Pagination -->
<div class="mt-3">
  <a class="btn btn-secondary @(ViewBag.Page <= 1 ? "disabled" : "")"
     asp-route-page="@(ViewBag.Page - 1)"
     asp-route-logType="@ViewBag.LogType"
     asp-route-actionFilter="@ViewBag.ActionFilter"
     asp-route-search="@ViewBag.Search"
     asp-route-userId="@ViewBag.UserId"
     asp-route-timeRange="@ViewBag.TimeRange"
     asp-route-fromDate="@ViewBag.FromDate"
     asp-route-toDate="@ViewBag.ToDate">
    Prev
  </a>

  <span class="mx-3">
    Page @ViewBag.Page / @ViewBag.TotalPages
  </span>

  <a class="btn btn-secondary @(ViewBag.Page >= ViewBag.TotalPages ? "disabled" : "")"
     asp-route-page="@(ViewBag.Page + 1)"
     asp-route-logType="@ViewBag.LogType"
     asp-route-actionFilter="@ViewBag.ActionFilter"
     asp-route-search="@ViewBag.Search"
     asp-route-userId="@ViewBag.UserId"
     asp-route-timeRange="@ViewBag.TimeRange"
     asp-route-fromDate="@ViewBag.FromDate"
     asp-route-toDate="@ViewBag.ToDate">
    Next
  </a>
</div>

<!-- JS to show/hide custom date inputs -->
@section Scripts {
  <script>
    const timeSelect = document.getElementById('timeRangeSelect');
    const customDates = document.getElementById('customDates');

    timeSelect.addEventListener('change', function () {
      if (this.value === 'custom') {
        customDates.classList.remove('d-none');
      } else {
        customDates.classList.add('d-none');
      }
    });
  </script>
}