@{
  ViewData["Title"] = "Energy Statistics";

  var labelsJson = System.Text.Json.JsonSerializer.Serialize(ViewBag.Labels ?? new List<string>());
  var consumptionJson = System.Text.Json.JsonSerializer.Serialize(ViewBag.Consumption ?? new List<decimal>());

  int selectedMonth = ViewBag.SelectedMonth;
  int selectedYear = ViewBag.SelectedYear;

  int currentYear = ViewBag.CurrentYear;
  int currentMonth = ViewBag.CurrentMonth;

  bool disableNext = selectedYear >= currentYear;
}

<h2 class="mb-4">Energy Usage Statistics</h2>

<form method="get" asp-controller="Statistics" asp-action="Index" class="mb-4">
  <div class="row align-items-end">

    <div class="col-md-3">
      <label>Month</label>
      <select name="month" class="form-control">
        @for (int m = 1; m <= 12; m++)
        {
          bool disableMonth = selectedYear == currentYear && m > currentMonth;

          <option value="@m"
                  selected="@(m == selectedMonth)"
                  disabled="@(disableMonth)">
            @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)
          </option>
        }
      </select>
    </div>

    <div class="col-md-3">
      <label>Year</label>
      <input type="number"
             name="year"
             value="@selectedYear"
             min="2000"
             max="@currentYear"
             class="form-control" />
    </div>

    <div class="col-md-6 mt-2">
      <button type="submit" class="btn btn-primary">
        Show
      </button>

      <a class="btn btn-secondary"
         asp-action="Index"
         asp-route-month="@selectedMonth"
         asp-route-year="@(selectedYear - 1)">
        ◀ Previous Year
      </a>

      <a class="btn btn-secondary @(disableNext ? "disabled" : "")"
         asp-action="Index"
         asp-route-month="@selectedMonth"
         asp-route-year="@(selectedYear + 1)">
        Next Year ▶
      </a>
    </div>
  </div>
</form>

<h5>
  Showing period:
  @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(selectedMonth)
  @(selectedYear - 1)
  →
  @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(selectedMonth)
  @selectedYear
</h5>

<hr />

@if (((List<string>)ViewBag.Labels)?.Any() == true)
{
  <div class="row">

    <!-- LINE CHART -->
    <div class="col-md-8">
      <canvas id="energyChart" height="100"></canvas>
    </div>

    <!-- PIE CHART -->
    <div class="col-md-4">
      <canvas id="pieChart"></canvas>
    </div>

  </div>
}
else
{
  <div class="alert alert-info mt-4">
    No consumption data available for selected period.
  </div>
}

@section Scripts {
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <script>
    document.addEventListener("DOMContentLoaded", function () {

        const labels = @Html.Raw(labelsJson);
        const dataValues = @Html.Raw(consumptionJson);

        if (!labels || labels.length === 0)
            return;

        // ===== LINE CHART =====
        const lineCtx = document.getElementById('energyChart').getContext('2d');

        new Chart(lineCtx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Consumption (kWh)',
                    data: dataValues,
                    borderColor: 'rgb(75, 192, 192)',
                    tension: 0.3,
                    fill: false
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });

    // ===== PIE CHART =====
    const pieCtx = document.getElementById('pieChart').getContext('2d');

    // dacă nu există date
    if (!dataValues || dataValues.length === 0)
        return;

    // detect min & max
    const maxValue = Math.max(...dataValues);
    const minValue = Math.min(...dataValues);

    // verificare dacă toate valorile sunt egale
    const allEqual = dataValues.every(v => v === dataValues[0]);

    let backgroundColors;

    if (allEqual) {
        // toate lunile au aceeași valoare
        backgroundColors = dataValues.map(() => '#6c757d'); // gri neutru
    } else {
        backgroundColors = dataValues.map(v => {
            if (v === maxValue)
                return '#dc3545'; // 🔴 maxim
            if (v === minValue)
                return '#198754'; // 🟢 minim
            return '#0d6efd';     // 🔵 normal
        });
    }

    new Chart(pieCtx, {
        type: 'pie',
        data: {
            labels: labels,
            datasets: [{
                data: dataValues,
                backgroundColor: backgroundColors
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { position: 'bottom' },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            let label = context.label || '';
                            let value = context.raw;

                            if (value === maxValue && !allEqual)
                                label += ' (Highest)';
                            else if (value === minValue && !allEqual)
                                label += ' (Lowest)';

                            return `${label}: ${value} kWh`;
                        }
                    }
                }
            }
        }
    });

    });
  </script>
}